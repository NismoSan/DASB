      <field name="Code" type="Byte" />
      <field name="Checksum" type="UInt32" />
      <field name="Seed" type="Byte" />
      <field name="Key" type="String8" />
    </opcode>
    <opcode hex="0x02" name="LoginMessage">
      <field name="Code" type="Byte" />
      <field name="Message" type="String8" />
    </opcode>
    <opcode hex="0x03" name="Redirect">
      <field name="Address" type="Bytes" length="4" />
      <field name="Port" type="UInt16" />
      <field name="Remaining" type="Byte" />
      <field name="Seed" type="Byte" />
      <field name="Key" type="String8" />
      <field name="Name" type="String8" />
      <field name="Id" type="UInt32" />
    </opcode>
    <opcode hex="0x04" name="MapLocation">
      <field name="X" type="UInt16" />
      <field name="Y" type="UInt16" />
    </opcode>
    <opcode hex="0x05" name="UserId">
