    <opcode hex="0x1A" name="Animation">
      <field name="Serial" type="UInt32" />
      <field name="AnimationId" type="UInt16" />
      <field name="Speed" type="UInt16" />
    </opcode>
    <opcode hex="0x1F" name="MapChanged" />
    <opcode hex="0x29" name="AnimateEntity">
      <field name="Serial" type="UInt32" />
      <field name="AnimationId" type="UInt16" />
      <field name="Speed" type="UInt16" />
      <field name="X" type="UInt16" />
      <field name="Y" type="UInt16" />
      <field name="Unknown" type="UInt16" />
    </opcode>
    <opcode hex="0x2C" name="AddSkill">
      <field name="Slot" type="Byte" />
