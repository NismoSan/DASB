    <opcode hex="0x0E" name="RemoveEntity">
      <field name="Serial" type="UInt32" />
    </opcode>
    <opcode hex="0x0F" name="AddWorldItem">
      <field name="X" type="UInt16" />
      <field name="Y" type="UInt16" />
      <field name="Serial" type="UInt32" />
      <field name="Sprite" type="UInt16" />
      <field name="Color" type="Byte" />
    </opcode>
    <opcode hex="0x11" name="EntityDirection">
      <field name="Serial" type="UInt32" />
      <field name="Direction" type="Byte" />
    </opcode>
    <opcode hex="0x15" name="MapData">
      <field name="MapNumber" type="UInt16" />
      <field name="MapWidth" type="Byte" />
      <field name="MapHeight" type="Byte" />
    </opcode>
    <opcode hex="0x17" name="AddSpell">
      <field name="Slot" type="Byte" />
      <field name="Sprite" type="UInt16" />
