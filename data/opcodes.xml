      <field name="Slot" type="Byte" />
      <field name="Sprite" type="UInt16" />
      <field name="Color" type="Byte" />
      <field name="Name" type="String8" />
      <field name="Count" type="UInt32" />
      <field name="Stackable" type="Byte" />
      <field name="MaxDurability" type="UInt32" />
      <field name="CurrentDurability" type="UInt32" />
    </opcode>
    <opcode hex="0x38" name="RemoveItem">
      <field name="Slot" type="Byte" />
    </opcode>
    <opcode hex="0x39" name="UpdateStats" />
