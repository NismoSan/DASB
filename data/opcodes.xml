    </opcode>
    <opcode hex="0x7E" name="Welcome" />
  </opcodes>

  <!-- Client-to-Server (Outgoing) Opcodes -->
  <opcodes direction="out">
    <opcode hex="0x00" name="Version">
      <field name="Version" type="Int16" />
      <field name="Patch" type="Byte" />
      <field name="Key" type="Byte" />
      <field name="Unknown" type="Byte" />
    </opcode>
    <opcode hex="0x03" name="Login">
