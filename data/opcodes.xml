    </opcode>
    <opcode hex="0x07" name="AddEntity">
      <field name="X" type="UInt16" />
      <field name="Y" type="UInt16" />
      <field name="Serial" type="UInt32" />
      <field name="Sprite" type="UInt16" />
      <field name="Unknown1" type="Bytes" length="4" />
      <field name="Direction" type="Byte" />
      <field name="Unknown2" type="Byte" />
      <field name="CreatureType" type="Byte" />
    </opcode>
    <opcode hex="0x08" name="RemoveEntity">
      <field name="Serial" type="UInt32" />
    </opcode>
    <opcode hex="0x0A" name="Chat">
      <field name="Channel" type="Byte" />
      <field name="Message" type="String8" />
    </opcode>
    <opcode hex="0x0B" name="WalkResponse">
      <field name="Direction" type="Byte" />
    </opcode>
    <opcode hex="0x0C" name="EntityWalk">
      <field name="Serial" type="UInt32" />
      <field name="X" type="UInt16" />
      <field name="Y" type="UInt16" />
      <field name="Direction" type="Byte" />
    </opcode>
    <opcode hex="0x0D" name="PublicMessage">
      <field name="Type" type="Byte" />
      <field name="Serial" type="UInt32" />
      <field name="Message" type="String8" />
