      <field name="Message" type="String8" />
    </opcode>
    <opcode hex="0x1D" name="Emote">
      <field name="EmoteId" type="Byte" />
    </opcode>
    <opcode hex="0x29" name="ExchangeRequest" />
    <opcode hex="0x2D" name="EnterWorld" />
    <opcode hex="0x38" name="Refresh" />
    <opcode hex="0x3F" name="WorldMapClick" />
    <opcode hex="0x43" name="UseSpell">
      <field name="Slot" type="Byte" />
    </opcode>
    <opcode hex="0x45" name="PongA">
      <field name="LoByte" type="Byte" />
      <field name="HiByte" type="Byte" />
    </opcode>
    <opcode hex="0x4A" name="ExchangeAction" />
    <opcode hex="0x57" name="EncryptAck">
      <field name="Unknown1" type="Byte" />
      <field name="Unknown2" type="Byte" />
      <field name="Unknown3" type="Byte" />
    </opcode>
    <opcode hex="0x62" name="MagicBytes">
      <field name="Byte1" type="Byte" />
      <field name="Byte2" type="Byte" />
      <field name="Byte3" type="Byte" />
      <field name="Byte4" type="Byte" />
      <field name="Byte5" type="Byte" />
      <field name="Byte6" type="Byte" />
      <field name="Byte7" type="Byte" />
      <field name="Byte8" type="Byte" />
    </opcode>
    <opcode hex="0x75" name="PongB">
      <field name="ServerTimestamp" type="Int32" />
      <field name="ClientTimestamp" type="Int32" />
    </opcode>
  </opcodes>
</protocol>
