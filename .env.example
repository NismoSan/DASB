# Dark Ages game server address
DA_SERVER_ADDRESS=127.0.0.1

# OpenAI API key (required for Chat Games feature)
OPENAI_API_KEY=sk-proj-your-key-here

# PostgreSQL database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dasb
DB_USER=postgres
DB_PASSWORD=your-password

# Web panel credentials
PANEL_USERNAME=admin
PANEL_PASSWORD=your-password

# Project root path
DA_PATH=/path/to/dasb

# Lottery draw verification secret (generate a random hex string)
LOTTERY_SECRET=your-secret-here

# Aisling Exchange API
AE_BACKEND_URL=https://api.aislingexchange.com
AE_INGEST_KEY=your-ingest-key
